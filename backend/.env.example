# ── Database ──────────────────────────────────────────────────────────
# Production (PostgreSQL on Render/Railway/any cloud):
#   postgresql+psycopg2://user:password@host:5432/retail_assistant
#   postgresql://user:password@host:5432/retail_assistant  (auto-detected)
#
# Local development (SQLite):
#   sqlite:///./retail_assistant.db
DATABASE_URL=sqlite:///./retail_assistant.db

# Connection pool settings (PostgreSQL only — ignored for SQLite)
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_RECYCLE=3600
# DB_POOL_PRE_PING=true

# ── App ───────────────────────────────────────────────────────────────
DEFAULT_PROFIT_MARGIN=15
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=./chroma_db
SECRET_KEY=change-this-to-a-random-secret
DEBUG=False
CORS_ORIGINS=https://your-frontend.vercel.app,https://your-custom-domain.com
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DEFAULT_USERNAME=janemaiks
DEFAULT_PASSWORD=change-this-password
